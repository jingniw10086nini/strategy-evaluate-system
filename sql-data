                                    ,SPLIT_PART(t2.preset_question_list, '||', 4)                                                        AS preset_question_4
                                    ,ROW_NUMBER() OVER (PARTITION BY t0.router_id ORDER BY DATEDIFF(t0.log_time, t2.log_time, 'ss') ASC) AS rn_2 -- 取“最接近会话最近一次的曝光”
