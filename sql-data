-- B)去重，保证一个router一行数据
,router_base AS
(
    SELECT  router_id
            ,user_id
            ,is_enter_man
            ,log_time   AS router_start_time
            ,dt
            ,scene_code
            ,spm_clean  AS anchor_spm_clean
            ,spm_b_name AS anchor_spm_b_name
            ,spm_c_name AS anchor_spm_c_name
            ,spm_d_name AS anchor_spm_d_name
            ,capability_name
            ,platform
            ,alipay_version
            ,phone_platform
            ,language
            ,network_type
            ,interactive_mode
            ,preset_question_list
            ,preset_question_1
            ,preset_question_2
            ,preset_question_3
            ,preset_question_4
            ,1          AS eligible
    FROM    (
                SELECT  a.*
                        ,ROW_NUMBER() OVER (PARTITION BY router_id ORDER BY log_time ASC) AS rn_3
                FROM    anchor_event a
            ) t
    WHERE   rn_3 = 1
)
,
-- C) 命中标：router级 hit_flag（用你的真实表替换）
hit AS
(
    SELECT  t.*
            ,1 AS hit_flag
    FROM    (
                SELECT  a.is_whitelist
                        ,b.*
                FROM    (
                            SELECT  *
                            FROM    (
                                        SELECT  '前端'                                                              AS exp_type
                                                ,experiment_id -- 实验id
                                                ,experiment_name --核心信息：实验名
                                                ,experiment_version_id --核心信息：实验版本id
                                                ,experiment_version_name --核心信息：实验版本名称
                                                ,user_id --用户id
                                                ,dt --分区
                                                ,experiment_status -- 实验状态  0:创建中,1:运行中,2:已下线,3:已删除,4:预发运行中,5:灰度验证,6:已推全,7:推全中
                                                ,DATEDIFF(gmt_create, experiment_start_time, 'dd')                  AS exp_days -- 实验运行时长（从创建时期到t+1）
                                                ,router_id
                                                ,is_whitelist
                                                ,ROW_NUMBER() OVER (PARTITION BY router_id ORDER BY gmt_create ASC) AS rn
                                        FROM    zfcdm_cc.dwd_crm_supp_darwin_exec_log_front_di -- 前端曝光实验
                                        WHERE   dt >= '${dt_start}'
                                        AND     dt <= '${dt_end}'
                                        AND     experiment_status NOT IN ('已删除', '3') -- 剔除已删除实验
                                        AND     experiment_name NOT RLIKE '测试' -- 剔除测试实验
                                        AND     experiment_id = '334200626'
                                        AND     experiment_version_name = '实验组_暖色调'
                                    )
                            WHERE   rn = 1
                        ) a
                JOIN    (
                            SELECT  *
                            FROM    (
                                        SELECT  *
                                                ,ROW_NUMBER() OVER (PARTITION BY router_id ORDER BY log_time ASC) AS rn
                                        FROM    zfcdm_cc.dws_crm_mypa_service_exploded_di
                                        WHERE   dt >= '${dt_start}'
                                        AND     dt <= '${dt_end}'
                                        AND     channel NOT IN ('FAQ')
                                    )
                            WHERE   rn = 1
                        ) b
                ON      a.router_id = b.router_id
                AND     a.dt = b.dt
            ) t
)
,
-- D) 满意度问卷：router级 satis_flag（用你的真实表替换）
survey AS
(
    SELECT  router_id
            ,is_online_sat_satisfaction AS satis_flag
    FROM    (
                SELECT  *
                        ,ROW_NUMBER() OVER (PARTITION BY router_id ORDER BY log_time ASC) AS rn
                FROM    zfcdm_cc.dws_crm_mypa_service_exploded_di
                WHERE   dt >= '${dt_start}'
                AND     dt <= '${dt_end}'
                AND     channel NOT IN ('FAQ')
            )
    WHERE   rn = 1
)
-- E) router汇总输出：一行一个router + post_flag + 组合特征
,router_summary AS
(
    -- 策略
    SELECT  b.router_id
            ,b.user_id
            ,COALESCE(SUBSTR(b.user_id, -1, 1), 'uid空')                     AS uid_last_1no -- 用户尾号倒1
            ,COALESCE(SUBSTR(b.user_id, -2, 1), 'uid空')                     AS uid_last_2no -- 用户尾号倒2
            ,COALESCE(SUBSTR(b.user_id, -3, 1), 'uid空')                     AS uid_last_3no -- 用户尾号倒3
            ,b.router_start_time
            ,b.dt
            ,CASE
                    WHEN b.dt >= '${bizdate}' THEN 1
                    ELSE 0
            END                                                              AS post_flag -- 是否实验上线日期
            ,h.is_whitelist -- 是否白名单用户
            -- 入口/场景
            ,b.scene_code
            ,t5.scene_business_name_level3
            ,t5.scene_biz_unit_1
            ,t5.scene_biz_unit_2
            ,t5.scene_biz_unit_3
            ,t5.scene_business_name_level1
            ,t5.scene_business_name_level2
            ,t5.scene_group
            -- anchor spm（最早一条 eligible 事件）
            ,b.anchor_spm_clean
            ,b.anchor_spm_b_name
            ,b.anchor_spm_c_name
            ,b.anchor_spm_d_name
            -- 组合特征,入口 * spm
            ,CONCAT(b.scene_code, '||', COALESCE(b.anchor_spm_clean, 'NA'))  AS scene_spm_clean -- 入口*SPM信息：去掉下划线后的spm
            ,CONCAT(b.scene_code, '||', COALESCE(b.anchor_spm_b_name, 'NA')) AS scene_spm_b_name -- 入口*SPM信息：b位名
            ,CONCAT(b.scene_code, '||', COALESCE(b.anchor_spm_c_name, 'NA')) AS scene_spm_c_name -- 入口*SPM信息：c位名
            ,CONCAT(b.scene_code, '||', COALESCE(b.anchor_spm_d_name, 'NA')) AS scene_spm_d_name -- 入口*SPM信息：d位名
            -- 端环境/版本/来源（取anchor行）
            ,b.capability_name
            ,b.platform
            ,b.alipay_version
            ,b.phone_platform
            ,b.language
            ,b.network_type
            ,b.interactive_mode
            ,b.preset_question_list -- 入口预设问题list，猜你想问曝光问题
            ,b.preset_question_1 -- 入口预设问题1
            ,b.preset_question_2 -- 入口预设问题2
           
            ,b.preset_question_3 -- 入口预设问题3
            ,b.preset_question_4 -- 入口预设问题4
            -- 日期
            ,t6.day_of_week -- 对话开始天段_周一到周日
            ,t6.holiday_flag -- 是否节假日
            ,t6.is_workday -- 是否工作日
            ,t6.weekend_flag -- 是否周末
            ,COALESCE(h.hit_flag, 0)                                         AS hit_flag -- 命中策略标
            ,s.satis_flag -- 是否满意
    FROM    router_base b
    LEFT JOIN   hit h
    ON      b.router_id = h.router_id
    LEFT JOIN   survey s
    ON      b.router_id = s.router_id
    LEFT JOIN   (
                    SELECT  *
                    FROM    antcc.adm_crm_dim_bi2_scene_group_dd
                ) t5
    ON      b.scene_code = t5.scene_code
    LEFT JOIN   (
                    SELECT  cal_str
                            ,CASE   dayofweek(TO_DATE(cal_str, 'yyyymmdd'))
                                    WHEN 1 THEN '周一'
                                    WHEN 2 THEN '周二'
                                    WHEN 3 THEN '周三'
                                    WHEN 4 THEN '周四'
                                    WHEN 5 THEN '周五'
                                    WHEN 6 THEN '周六'
                                    WHEN 7 THEN '周日'
                            END AS day_of_week -- 对话开始天段_周一到周日
                            ,holiday_flag -- 是否节假日
                            ,is_workday -- 是否工作日
                            ,weekend_flag -- 是否周末
                    FROM    antddm.adm_ddm_hy_holiday_info
                    WHERE   dt = '${dt_end}'
                    AND     cal_str >= '${dt_start}'
                    AND     cal_str <= '${dt_end}'
                ) t6
    ON      b.dt = t6.cal_str
    WHERE   b.eligible = 1 -- 在候选流量池内
    AND     s.satis_flag IS NOT NULL -- 只保留有问卷的router
)
,
-- F) router汇总输出 + uid对应用户特征
router_user_summary AS
(
    SELECT  r.*
            -- 用户特征（只放你需要的字段；这里示例放一部分，你可以全放）
            ,u.zfb_account_user_age --支付宝用户年龄
            ,u.zfb_account_user_gender --支付宝用户性别
            ,u.zfb_user_prov_name --支付宝用户常驻省份名称
