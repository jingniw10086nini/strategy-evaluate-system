                                                    ORDER BY REGEXP_EXTRACT(spm, '_(\\d+)$', 1) ASC
                                                )
                                        GROUP BY router_id
                                                ,log_time
                                                ,dt
                                    ) t2
                            ON      t0.router_id = t2.router_id
                            AND     t0.dt = t2.dt
                            AND     DATEDIFF(t0.log_time, t2.log_time, 'ss') BETWEEN 0 AND 300 -- 取对话前猜你想问曝光问题，限定5min前
