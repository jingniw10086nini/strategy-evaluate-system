                                        WHERE   rn = 1
                                    ) t0
                            JOIN    (
                                        SELECT  *
                                                ,REGEXP_EXTRACT(spm, '_(\\d+)$', 1)             AS spm_code -- 点位
                                                ,KEYVALUE(exinfo4, '^', '=', 'alipayVersion')   AS alipay_version -- 系统版本号
                                                ,KEYVALUE(exinfo4, '^', '=', 'platform')        AS phone_platform -- 手机设备型号
