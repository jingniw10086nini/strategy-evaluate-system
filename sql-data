                                    ,t1.language -- app语言
                                    ,t1.network_type -- 网络类型
                                    ,t1.interactive_mode -- 初始化模块
                                    ,CASE
                                            WHEN t2.router_id IS NOT NULL THEN 1
                                            ELSE 0
