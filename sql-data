                                                ,KEYVALUE(exinfo4, '^', '=', 'interactiveMode') AS interactive_mode -- 初始化模块
                                        FROM    (
                                                    SELECT  *
                                                    FROM    zfcdm_cc.dwd_crm_mypa_service_detail_di
                                                    WHERE   dt >= '${dt_start}'
                                                    AND     dt <= '${dt_end}'
                                                    AND     exinfo4 IS NOT NULL
                                                )
                                    ) t1
                            ON      t0.router_id = t1.router_id
                            AND     t0.dt = t1.dt
                            AND     t0.log_time = t1.log_time
                            JOIN    (
                                        SELECT  router_id
