            ,u.zfb_account_type --支付宝用户类型(1:公司,u.2:个人,u.0:未知)
            ,u.zfb_account_create_days --用户注册天数
            ,u.zfb_account_enabled_status --支付宝账户激活状态(T:正常,u.B:冻结,u.W:注册未激活,u.Q:快速注册,u.C:注销)
            ,u.user_type --用户类型(1:公司/2:个人/3:内部户/6:担保户/8:总账/99:历史脏数据)
            ,u.user_sub_type --用户子类型(CO:公司/SINGLE:个体工商户/INST:事业单位/COMM:社会团体/NGO:民办非企业组织/STATEORGAN:党政国家机关/FIN:金融机构/SCORP:特殊单位/VIRO:虚拟主体,u.个人用户为空）
            ,u.user_status --用户状态(T:正常/B:冻结/W:注册未激活/Q:快速注册/C:注销)
            ,u.profession --职业
            ,u.account_level --账户等级(L0/L1/L2/L3,u.企业没有账户等级,u.详见https://yuque.antfin-inc.com/uu8too/cyhsff/sbn6zm#RbIFS)
            ,u.user_tag --人群分层标，具体见：https://yuque.antfin.com/docs/share/1e2b68c4-4680-4b34-bbf9-1471208e6aea?# 《用户人群分层表说明》
            ,u.is_k12_flag --是否K12，0-否/1-是，实名， 6-17岁
            ,u.is_daxuesheng_flag --是否大学生，0-否/1-是，实名，18岁及以上，大学生
            ,u.is_qinzirenqun_flag --是否亲子人群，0-否/1-是，实名，本人18岁及以上，孩子年龄18岁及以下
            ,u.is_xiaoweishangjia_flag --是否小微商家，0-否/1-是 收钱码商家
            ,u.is_lanling_flag --是否蓝领
            ,u.is_bailing_flag --是否白领
            ,u.user_education --学历
            ,u.is_realname_flag --是否实名
            ,u.usr_actv_flag --用户活性，仅MAU有值
            ,u.glc_tag --用户生命周期
            ,u.salary_level --用户消费分层
            ,u.is_dau --是否DAU用户
            ,u.is_mau --是否MAU用户
            ,u.is_aau --是否AAU用户
            ,u.last_dau_dt_diff --最近一次活跃的日期间隔，0-当日活跃，N-最近活跃在N天前
            ,u.user_login_type --用户分层标签：当月新登-近一个月新登录用户；高活复登-近3个月高活老用户且每个月登陆天数 >= 20天；中活复登-近3个月中活老用户且每个月登陆天数<20天但大于等于8天；低活复登-至少近两个月登陆天数<8天但大于等于1天
            ,u.new_user_tag --新老用户标签
            ,u.is_black_user --是否风控黑名单用户
            ,u.usr_login_days_7d -- 近7天登录天数
            ,u.usr_login_days_30d -- 近30天登录天数
            ,u.usr_login_days_90d -- 近90天登录天数
            ,u.zfb_login_cnt_30d -- 近30天登录次数
            ,u.7d_router_cnt -- 近7天智能服务量
            ,u.30d_router_cnt -- 近30天智能服务量
            ,u.7d_enter_man_cnt -- 近7天转人工会话router量
            ,u.30d_enter_man_cnt -- 近30天转人工会话router量
            ,u.7d_ticket_cnt --  近7天提交工单量
            ,u.30d_ticket_cnt --  近30天提交工单量
            ,u.7d_is_shengtou --  近7天是否提交过升投工单
            ,u.30d_is_shengtou --  近30天是否提交过升投工单
            ,u.7d_is_jianguan --   近7天是否提交过监管工单
            ,u.30d_is_jianguan --  近30天是否提交过监管工单
            ,COALESCE(t2_agg.is_unfinished_ticket, 0)  AS is_unfinished_ticket -- 对话前该用户是否存在未完结工单
            ,COALESCE(t2_agg.unfinished_ticket_cnt, 0) AS unfinished_ticket_cnt -- 对话前未完结工单数
            ,t2_agg.recent_unfinished_ticket_days      AS recent_unfinished_ticket_days -- 对话前距离最近一次工单创建天数
    FROM    router_summary r
    -- 1) 用户画像：用 dt = bizdate - 1 的快照，上线日-1
    LEFT JOIN   (
                    SELECT  *
                    FROM    antcc.adm_crm_user_tag_mypa_svc_detail
                    WHERE   dt = TO_CHAR(DATEADD(TO_DATE('${bizdate}', 'yyyymmdd'), -1, 'dd'), 'yyyymmdd')
                ) u
    ON      u.user_id = r.user_id
    -- 2) 未完结工单：先聚合到 router_id 粒度，避免 router 被打散成多行
    LEFT JOIN   (
                    SELECT  r2.router_id
                            ,1 AS is_unfinished_ticket
                            ,t2.unfinished_ticket_cnt
                            ,t2.recent_unfinished_ticket_days
                    FROM    router_summary r2
                    JOIN    (
                                -- 先在 user 粒度算“上线前快照未完结工单状态”
                                SELECT  t.user_id
                                        ,COUNT(1)                                                             AS unfinished_ticket_cnt
                                        ,MIN(DATEDIFF(TO_DATE('${bizdate}', 'yyyymmdd'), t.gmt_create, 'dd')) AS recent_unfinished_ticket_days
                                FROM    antcc.adm_evt_crm_os_wt_ticket_delay_index_extend_di t
                                WHERE   t.dt >= TO_CHAR(DATEADD(TO_DATE('${bizdate}', 'yyyymmdd'), -90, 'dd'), 'yyyymmdd')
                                AND     t.dt <= TO_CHAR(DATEADD(TO_DATE('${bizdate}', 'yyyymmdd'), -1, 'dd'), 'yyyymmdd') -- 只用上线前数据
                                AND     t.user_id != '2088'
                                AND     t.state NOT IN ('结束', '撤销')
                                -- 关键：用“上线日00:00”作为快照时点判断是否未完结
                                AND     t.gmt_create < TO_DATE('${bizdate}', 'yyyymmdd')
                                AND     (
                                            t.gmt_end IS NULL
                                            OR      t.gmt_end >= TO_DATE('${bizdate}', 'yyyymmdd')
                                        )
                                GROUP BY t.user_id
                            ) t2
                    ON      r2.user_id = t2.user_id
                ) t2_agg
    ON      r.router_id = t2_agg.router_id
)
SELECT  *
FROM    router_user_summary;
