def force_str_fast(s: pd.Series) -> pd.Series:
    return s.where(s.notna(), "NA").astype(str)

# 2.1 先把所有 object/string/category 直接转成纯字符串（最省事、最不容易炸）
obj_like = data_fe.select_dtypes(include=["object", "string", "category"]).columns.tolist()
print("[parquet fix] obj_like cols:", len(obj_like))

for c in obj_like:
    data_fe[c] = force_str_fast(data_fe[c])
    if c in user_pre.columns:
        user_pre[c] = force_str_fast(user_pre[c])

# 2.2 再额外修一类常见“本应是数值但被污染成object”的列：
#     规则：列名里带 flag/cnt/days/level/diff 且 dtype 还是 object -> 尝试转 numeric
maybe_num_patterns = ("flag", "cnt", "days", "diff", "level", "grade")
maybe_num = [
    c for c in data_fe.columns
    if (data_fe[c].dtype == "object")
    and any(p in c for p in maybe_num_patterns)
]

print("[parquet fix] maybe numeric-but-object cols:", len(maybe_num))

for c in maybe_num:
    v = pd.to_numeric(data_fe[c], errors="coerce")
    # 这里不要填 0，避免改分布；保留 NaN 给后续模型/处理
    data_fe[c] = v
