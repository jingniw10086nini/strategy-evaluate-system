import numpy as np
import pandas as pd
import re

def winsorize_series(s: pd.Series, upper=0.995) -> pd.Series:
    x = pd.to_numeric(s, errors="coerce")
    hi = x.quantile(upper)
    if not np.isfinite(hi):
        return x
    return x.clip(upper=hi)

def bin_days_gap_custom(s: pd.Series) -> pd.Series:
    x = pd.to_numeric(s, errors="coerce")
    bins = [-np.inf, 0, 1, 3, 7, 14, 30, 60, 90, np.inf]
    labels = ["0","1","2-3","4-7","8-14","15-30","30-60","60-90","90+"]
    return pd.cut(x, bins=bins, labels=labels).astype("object").fillna("NA")

def bin_create_days(s: pd.Series) -> pd.Series:
    s = pd.to_numeric(s, errors="coerce")
    bins = [-np.inf, 30, 90, 180, 365, 730, 1095, np.inf]
    labels = ["0-30","31-90","91-180","181-365","1-2y","2-3y","3y+"]
    return pd.cut(s, bins=bins, labels=labels).astype("object").fillna("NA")


# ---------- 优化1：TopN 只在 pre 行算一次 ----------
def build_top_map(df_pre: pd.DataFrame, cols: list, topn: int):
    """返回 {col: set(top_values)}"""
    top_map = {}
    for c in cols:
        if c in df_pre.columns:
            s = df_pre[c].fillna("NA").astype(str)
            top_map[c] = set(s.value_counts().head(topn).index)
    return top_map

def apply_top_map(s: pd.Series, top_set: set):
    s = s.fillna("NA").astype(str)
    return s.where(s.isin(top_set), "OTHER")


def preprocess_for_user_ps_features(df_panel: pd.DataFrame,
                                    upper_q: float = 0.995,
                                    verbose: bool = True) -> (pd.DataFrame, list):
    df = df_panel.copy()

    # ---------- forbid：不进 PS ----------
    forbid = set(META_COLS + [USER_ID, POST, D])
    for k, (n, dn) in NUM_DEN.items():
        forbid |= {n, dn, f"y_{k}"}
    forbid |= {"router_cnt"}  # 你说 router_cnt 要保留算指标，但不进 PS

    feature_cols = [c for c in df.columns if c not in forbid]
    X = df[feature_cols].copy()

    if verbose:
        print("forbid size:", len(forbid))
        print("feature_cols size:", len(feature_cols))

    # ==========================================================
    # Step A：识别 pre_* 列（兼容有/无 top5_share、nunique）
    # ==========================================================
    pre_top1_cols  = [c for c in X.columns if re.match(r"^pre_.*_top1$", c)]
    pre_share_cols = [c for c in X.columns if re.match(r"^pre_.*_top1_share$", c)]
    # 如果你还有 top5_share / nunique，这里也兼容（有就处理，没有就空）
    pre_share_cols += [c for c in X.columns if re.match(r"^pre_.*_top5_share$", c)]
    pre_nuniq_cols  = [c for c in X.columns if re.match(r"^pre_.*_nunique$", c)]

    # ==========================================================
    # Step B（优化2）：只处理“必要的 object 列”
    #   只对：TopN候选列、enum列、你原 topn_rules 涉及列 做 fillna/astype(str)
    # ==========================================================
    enum_like = [
        "zfb_account_user_gender","zfb_account_type","user_type",
        "is_k12_flag","is_daxuesheng_flag","is_qinzirenqun_flag",
        "is_xiaoweishangjia_flag","is_lanling_flag","is_bailing_flag",
        "is_realname_flag","is_black_user",
        "is_dau","is_mau","is_aau","new_user_tag",
        "zfb_account_is_froze_flag",
    ]
    base_topn_cols = [
        "scene_code","phone_platform","user_resident_city_name","zfb_user_area_name",
        "forecast_occupation_std_dft","profession","alipay_version",
        "user_login_type","glc_tag","salary_level","account_level","antmbr_current_grade",
    ]

    need_obj_cols = list(dict.fromkeys([c for c in (pre_top1_cols + base_topn_cols + enum_like) if c in X.columns]))
    for c in need_obj_cols:
        X[c] = X[c].fillna("NA").astype(str)

    # ==========================================================
    # Step C：数值列基础处理（只对明确是数值的列）
    #   share/nuniq 强制 numeric；其他 numeric 列：缺失填中位数
    # ==========================================================
    # 1) share/nuniq
    for c in pre_share_cols:
        v = pd.to_numeric(X[c], errors="coerce")
        X[c] = v.fillna(0.0).clip(0.0, 1.0)

    for c in pre_nuniq_cols:
        v = pd.to_numeric(X[c], errors="coerce").fillna(0.0)
        X[c] = winsorize_series(v, upper=upper_q).fillna(0.0)

    # 2) 其他数值列（不含 pre_top1 这种类别列）
    #    注意：不要强行把所有 object 转数值，会很慢；这里只处理“本来就是数值 dtype”的
    num_cols = X.select_dtypes(include=[np.number]).columns.tolist()
    for c in num_cols:
        v = pd.to_numeric(X[c], errors="coerce")
        X[c] = v.fillna(v.median())

    # ==========================================================
    # Step D（优化1）：TopN 压缩只用 pre 行统计，再映射到全量
    # ==========================================================
    pre_mask = (df[POST] == 0) if POST in df.columns else np.ones(len(df), dtype=bool)
    X_pre = X.loc[pre_mask].copy()

    # 你 router 聚合列的 TopN 口径
    topn_cols_200 = [
        "pre_scene_code_top1","pre_scene_group_top1",
        "pre_scene_business_name_level1_top1","pre_scene_business_name_level2_top1","pre_scene_business_name_level3_top1",
        "pre_scene_biz_unit_1_top1","pre_scene_biz_unit_2_top1","pre_scene_biz_unit_3_top1",
        "pre_phone_platform_top1","pre_platform_top1","pre_network_type_top1","pre_interactive_mode_top1","pre_language_top1",
        "scene_code","phone_platform"
    ]
    topn_cols_300 = [
        "pre_alipay_version_top1","pre_capability_name_top1",
        "pre_preset_question_1_top1","pre_preset_question_2_top1","pre_preset_question_3_top1","pre_preset_question_4_top1",
        "alipay_version","user_resident_city_name"
    ]
    topn_cols_500 = [
        "pre_scene_spm_clean_top1","pre_scene_spm_b_name_top1","pre_scene_spm_c_name_top1","pre_scene_spm_d_name_top1",
        "pre_anchor_spm_clean_top1","pre_anchor_spm_b_name_top1","pre_anchor_spm_c_name_top1","pre_anchor_spm_d_name_top1",
        "zfb_user_area_name"
    ]
    topn_cols_100 = ["forecast_occupation_std_dft","profession"]

    top_map = {}
    top_map.update(build_top_map(X_pre, topn_cols_200, 200))
    top_map.update(build_top_map(X_pre, topn_cols_300, 300))
    top_map.update(build_top_map(X_pre, topn_cols_500, 500))
    top_map.update(build_top_map(X_pre, topn_cols_100, 100))

    for c, top_set in top_map.items():
        X[c] = apply_top_map(X[c], top_set)

    # ==========================================================
    # Step E：days 分箱（保持你的逻辑）
    # ==========================================================
    if "zfb_account_create_days" in X.columns:
        X["zfb_account_create_days_bin"] = bin_create_days(X["zfb_account_create_days"])
        X = X.drop(columns=["zfb_account_create_days"])

    days_cols = [c for c in X.columns if ("days" in c and not c.endswith("_bin"))]
    for c in days_cols:
        X[c + "_bin"] = bin_days_gap_custom(X[c])
        X = X.drop(columns=[c])

    # ==========================================================
    # Step F：cnt 类长尾处理
    # ==========================================================
    cnt_cols = [c for c in X.columns if ("cnt" in c and not c.endswith("_log1p"))]
    for c in cnt_cols:
        v = pd.to_numeric(X[c], errors="coerce").fillna(0.0)
        v = winsorize_series(v, upper=upper_q).fillna(0.0)
        X[c + "_log1p"] = np.log1p(v)
        X = X.drop(columns=[c])

    # ==========================================================
    # Step G：enum -> 类别字符串（保留你的逻辑）
    # ==========================================================
    for c in enum_like:
        if c in X.columns:
            X[c] = pd.to_numeric(X[c], errors="coerce").astype("Int64").astype("object").fillna("NA")

    # 回写
    df = df.drop(columns=feature_cols)
    df = pd.concat([df, X], axis=1)
    feature_cols2 = X.columns.tolist()

    return df, feature_cols2

