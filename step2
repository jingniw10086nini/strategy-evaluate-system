def annotate_bars_vertical(ax, fmt="value", value_decimals=3, pct_decimals=2, pad=3):
    for p in ax.patches:
        h = p.get_height()
        if h is None or np.isnan(h):
            continue
        if fmt == "percent":
            s = f"{h*100:.{pct_decimals}f}%"
        elif fmt == "auto":
            s = f"{h*100:.{pct_decimals}f}%" if 0 <= h <= 1 else f"{h:.{value_decimals}f}"
        else:
            s = f"{h:.{value_decimals}f}"
        ax.annotate(s, (p.get_x() + p.get_width()/2, h),
                    ha="center", va="bottom", xytext=(0, pad),
                    textcoords="offset points", fontsize=8)

def auto_ylim(values, pad_ratio=0.30, min_pad=1e-6, floor_at_zero=True):
    v = np.asarray(values, dtype=float)
    v = v[~np.isnan(v)]
    if len(v) == 0:
        return (0, 1)
    vmin, vmax = float(v.min()), float(v.max())
    if np.isclose(vmin, vmax):
        pad = max(abs(vmax)*pad_ratio, min_pad)
        lo, hi = vmin-pad, vmax+pad
    else:
        span = vmax - vmin
        pad = max(span*pad_ratio, min_pad)
        lo, hi = vmin-pad, vmax+pad
    if floor_at_zero and lo < 0 and vmin >= 0:
        lo = 0.0
    return lo, hi
