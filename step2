def plot_one_metric(ax, df, col):
    df[col].plot(kind="bar", ax=ax, color=["#4C78A8", "#F58518"])
    ax.set_title(col, fontsize=11)
    ax.grid(axis="y", linestyle="--", alpha=0.25)
