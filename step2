    if col in ["auc"]:
        annotate_bars_vertical(ax, fmt="percent", pct_decimals=2)
    elif col.startswith("overlap_") or col == "trim_drop_rate":
        annotate_bars_vertical(ax, fmt="percent", pct_decimals=2)
    elif col.endswith("_sec"):
        annotate_bars_vertical(ax, fmt="value", value_decimals=1)
    elif ("smd" in col) or ("logloss" in col) or ("brier" in col) or ("ece" in col) or ("ps_" in col) or ("att_" in col):
