def summarize_att_weights(D, ps, clip=ATT_CLIP):
    D = np.asarray(D).astype(int)
    ps = np.clip(np.asarray(ps, float), 1e-6, 1-1e-6)
    w = np.where(D == 1, 1.0, ps / (1 - ps))
    w = np.minimum(w, clip)
    qs = np.quantile(w, [0, 0.5, 0.9, 0.95, 0.99, 1.0])
    return {
        "w_min": float(qs[0]),
        "w_p50": float(qs[1]),
        "w_p90": float(qs[2]),
        "w_p95": float(qs[3]),
        "w_p99": float(qs[4]),
        "w_max": float(qs[5]),
        "w_mean_control": float(w[D==0].mean()) if (D==0).any() else np.nan,
        "w_mean_treated": float(w[D==1].mean()) if (D==1).any() else np.nan,
    }

