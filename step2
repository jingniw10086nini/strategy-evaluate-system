CAT_BASE = dict(
    loss_function="Logloss",
    eval_metric="AUC",
    iterations=1200,
    early_stopping_rounds=80,
    random_seed=RANDOM_STATE,
    verbose=False,
    allow_writing_files=False,
    thread_count=-1,
    one_hot_max_size=20,
    max_ctr_complexity=1,
    ctr_leaf_count_limit=1000,
    model_size_reg=5.0,
)

def log_uniform(rng, low, high):
    return float(np.exp(rng.uniform(np.log(low), np.log(high))))

def sample_catboost_params(rng):
    # --------- 收紧范围：更稳更平滑 ----------
    return dict(
        depth=int(rng.integers(4, 8)),                    # 4~7
        learning_rate=log_uniform(rng, 0.03, 0.08),       # 0.03~0.08（收紧）
        l2_leaf_reg=log_uniform(rng, 8.0, 60.0),          # 略收紧，避免过激
        min_data_in_leaf=int(rng.choice([1200, 2000])),   # 只留 1200/2000（更平滑）
        rsm=float(rng.uniform(0.75, 1.0)),
        subsample=float(rng.uniform(0.65, 0.90)),
        bagging_temperature=float(rng.uniform(0.0, 0.8)),
        random_strength=float(rng.uniform(0.0, 2.0)),
        border_count=int(rng.choice([64, 128])),
    )

def fit_predict_cat_with_pool(pool_tr, pool_va, X_va, params, base=None):
    if base is None:
        base = CAT_BASE
    model = CatBoostClassifier(**base, **params)
    model.fit(pool_tr, eval_set=pool_va)
    ps_va = model.predict_proba(X_va)[:, 1]
    return model, ps_va
