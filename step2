def shap_mean_abs_catboost(model, X, positive_class=1):
    expl = shap.TreeExplainer(model, feature_perturbation="tree_path_dependent")
    sv = expl.shap_values(X)

    if isinstance(sv, (list, tuple)):
        vals = sv[positive_class]
    else:
        vals = sv
    vals = np.asarray(vals)
    if vals.ndim == 3:
        vals = vals[:, :, positive_class]
    return pd.Series(np.mean(np.abs(vals), axis=0), index=X.columns).sort_values(ascending=False)

