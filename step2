def build_topk_onehot_diag(dfX, cat_cols, topk=30, max_cols=50):
    diag = pd.DataFrame(index=dfX.index)
    use_cols = cat_cols[:max_cols]
    for c in use_cols:
        s = dfX[c].astype("string").fillna("NA")
        top_vals = s.value_counts().head(topk).index.tolist()
        for v in top_vals:
            diag[f"{c}=={v}"] = (s == v).astype(np.int8)
    return diag, use_cols

