def ece_score(y, ps, n_bins=20):
    y = np.asarray(y).astype(float)
    ps = np.asarray(ps).astype(float)
    bins = np.linspace(0, 1, n_bins + 1)
    idx = np.digitize(ps, bins) - 1
    ece = 0.0
    for b in range(n_bins):
        m = idx == b
        if m.sum() == 0:
            continue
        ece += (m.mean()) * abs(y[m].mean() - ps[m].mean())
    return float(ece)

def overlap_stats(ps):
    ps = np.asarray(ps, dtype=float)
    return dict(
        p_lt_0_01=float((ps < 0.01).mean()),
        p_gt_0_99=float((ps > 0.99).mean()),
        p_p01=float(np.quantile(ps, 0.01)),
        p_p99=float(np.quantile(ps, 0.99)),
        p_min=float(ps.min()),
        p_max=float(ps.max()),
    )

def ess(w):
    w = np.asarray(w, dtype=float)
    sw = w.sum()
    return float((sw**2) / (np.sum(w**2) + 1e-12))

def ipw_att_weights(D, ps, clip=50.0):
    D = np.asarray(D).astype(int)
    ps = np.clip(np.asarray(ps, dtype=float), 1e-6, 1 - 1e-6)
    w = np.where(D == 1, 1.0, ps / (1 - ps))
    return np.minimum(w, clip)

def weight_summary(w):
    w = np.asarray(w, dtype=float)
    qs = np.quantile(w, [0.5, 0.9, 0.95, 0.99])
    return dict(
        w_p50=float(qs[0]),
        w_p90=float(qs[1]),
        w_p95=float(qs[2]),
        w_p99=float(qs[3]),
        w_max=float(w.max()),
    )

def wmean(x, w):
    x = np.asarray(x, dtype=float)
    w = np.asarray(w, dtype=float)
    return float(np.sum(w * x) / (np.sum(w) + 1e-12))

def wvar(x, w):
    mu = wmean(x, w)
    x = np.asarray(x, dtype=float)
    w = np.asarray(w, dtype=float)
    return float(np.sum(w * (x - mu) ** 2) / (np.sum(w) + 1e-12))

def smd_weighted(x, D, w):
    x = np.asarray(x, dtype=float)
    D = np.asarray(D).astype(int)
    w = np.asarray(w, dtype=float)
    m1 = D == 1
    m0 = D == 0
    mu1, mu0 = wmean(x[m1], w[m1]), wmean(x[m0], w[m0])
    v1, v0 = wvar(x[m1], w[m1]), wvar(x[m0], w[m0])
    denom = np.sqrt((v1 + v0) / 2.0) + 1e-12
    return float((mu1 - mu0) / denom)

def smd_summary_numeric(df, num_cols, D, w):
    smds = []
    for c in num_cols:
        x = pd.to_numeric(df[c], errors="coerce").values
        x = np.nan_to_num(x, nan=np.nanmedian(x))
        smds.append(abs(smd_weighted(x, D, w)))
    smds = np.asarray(smds, dtype=float)
    if len(smds) == 0:
        return dict(dim=0, mean=np.nan, p90=np.nan, max=np.nan, lt_0_1=np.nan)
    return dict(
        dim=int(len(smds)),
        mean=float(np.nanmean(smds)),
        p90=float(np.nanquantile(smds, 0.90)),
        max=float(np.nanmax(smds)),
        lt_0_1=float(np.nanmean(smds < 0.1)),
    )

def smd_summary_onehot(diag_oh_df, D, w):
    smds = []
    for c in diag_oh_df.columns:
        x = diag_oh_df[c].values.astype(float)
        smds.append(abs(smd_weighted(x, D, w)))
    smds = np.asarray(smds, dtype=float)
    if len(smds) == 0:
        return dict(dim=0, mean=np.nan, p90=np.nan, max=np.nan, lt_0_1=np.nan)
    return dict(
        dim=int(len(smds)),
        mean=float(np.nanmean(smds)),
        p90=float(np.nanquantile(smds, 0.90)),
        max=float(np.nanmax(smds)),
        lt_0_1=float(np.nanmean(smds < 0.1)),
    )

def get_trim_bounds_common_support(ps, D, q_low=None, q_high=None):
    if q_low is None:  q_low = TRIM_Q_LOW
    if q_high is None: q_high = TRIM_Q_HIGH
    ps = np.asarray(ps, dtype=float)
    D  = np.asarray(D, dtype=int)
    ps_t = ps[D == 1]
    ps_c = ps[D == 0]
    lo = max(np.quantile(ps_t, q_low),  np.quantile(ps_c, q_low))
    hi = min(np.quantile(ps_t, q_high), np.quantile(ps_c, q_high))
    return float(lo), float(hi)

def apply_trimming_by_bounds(df, diag_df, ps, lo, hi):
    ps = np.asarray(ps, dtype=float)
    mask = (ps >= lo) & (ps <= hi)
    return df.loc[mask].copy(), diag_df.loc[mask].copy(), ps[mask].copy(), mask

def _att_metrics(df_, diag_, D_, ps_):
    w_att = ipw_att_weights(D_, ps_, clip=ATT_CLIP)
    ws = weight_summary(w_att)

    out = {}
    out["att_ess_treated"]  = ess(w_att[D_ == 1])
    out["att_ess_control"]  = ess(w_att[D_ == 0])
    out["att_w_p99"]        = ws["w_p99"]
    out["att_w_max"]        = ws["w_max"]

    bal_num = smd_summary_numeric(df_, balance_num_cols, D_, w_att)
    out["att_num_smd_mean"] = bal_num["mean"]
    out["att_num_smd_p90"]  = bal_num["p90"]
    out["att_num_smd_max"]  = bal_num["max"]
    out["att_num_smd_lt_0_1"] = bal_num["lt_0_1"]

    bal_cat = smd_summary_onehot(diag_, D_, w_att)
    out["att_cat_smd_mean"] = bal_cat["mean"]
    out["att_cat_smd_p90"]  = bal_cat["p90"]
    out["att_cat_smd_max"]  = bal_cat["max"]
    out["att_cat_smd_lt_0_1"] = bal_cat["lt_0_1"]

    return out

def eval_trial(va_df, diag_va_df, ps_va):
    D = va_df[D_COL].values.astype(int)
    ps = np.clip(np.asarray(ps_va, dtype=float), 1e-6, 1 - 1e-6)

    m = dict(
        auc=float(roc_auc_score(D, ps)),
        logloss=float(log_loss(D, ps)),
        brier=float(brier_score_loss(D, ps)),
        ece=float(ece_score(D, ps, n_bins=N_BINS_ECE)),
        ps_mean=float(ps.mean()),
        ps_p99_p01=float(np.quantile(ps, 0.99) - np.quantile(ps, 0.01)),
    )

    m.update({f"overlap_{k}": v for k, v in overlap_stats(ps).items()})
    m.update({f"raw_{k}": v for k, v in _att_metrics(va_df, diag_va_df, D, ps).items()})

    lo, hi = get_trim_bounds_common_support(ps, D, q_low=TRIM_Q_LOW, q_high=TRIM_Q_HIGH)
    m["trim_lo"] = float(lo)
    m["trim_hi"] = float(hi)

    va_t, diag_t, ps_t, mask = apply_trimming_by_bounds(va_df, diag_va_df, ps, lo, hi)
    D_t = va_t[D_COL].values.astype(int)

    m["trim_drop_rate"] = float(1.0 - mask.mean())
    m["trim_n"] = int(mask.sum())
    m["trim_treated_rate"] = float(D_t.mean())

    m.update({f"trim_overlap_{k}": v for k, v in overlap_stats(ps_t).items()})

    if (D_t.sum() > 0) and ((D_t == 0).sum() > 0):
        m.update({f"trim_{k}": v for k, v in _att_metrics(va_t, diag_t, D_t, ps_t).items()})
    else:
        for k in _att_metrics(va_df, diag_va_df, D, ps).keys():
            m[f"trim_{k}"] = np.nan

    return m

def score_trial(metrics, treated_rate):
    ps_spread = float(metrics.get("ps_p99_p01", np.nan))

    # ====== 动态阈值（分层）======
    # treated 很小的时候，p99-p01 可能就是很难大（这是现实）
    if treated_rate < 0.005:      # <0.5%
        ps_spread_thr = 0.0015
    elif treated_rate < 0.02:     # 0.5%~2%（你在这里）
        ps_spread_thr = 0.0030
    else:
        ps_spread_thr = max(0.005, 0.6 * treated_rate)

    if (not np.isfinite(ps_spread)) or (ps_spread < ps_spread_thr):
        return False, 1e9, f"ps_nearly_constant(ps_spread={ps_spread:.5f}<thr={ps_spread_thr:.5f})"

    # ===== 以下保持你原来的 hard gate（可先不动）=====
    if (not np.isfinite(metrics["trim_drop_rate"])) or metrics["trim_drop_rate"] > TRIM_DROP_MAX:
        return False, 1e9, "trim_too_much_or_invalid"
    if metrics["trim_n"] < 500:
        return False, 1e9, "trim_n_too_small"
    if metrics["trim_overlap_p_gt_0_99"] > 0.01:
        return False, 1e9, "trim_overlap_high"
    if (not np.isfinite(metrics["trim_att_ess_control"])) or metrics["trim_att_ess_control"] < 300:
        return False, 1e9, "trim_ess_control_low"
    if metrics["trim_att_num_smd_max"] > 0.30:
        return False, 1e9, "trim_num_balance_bad"
    if metrics["trim_att_cat_smd_max"] > 0.55:
        return False, 1e9, "trim_cat_balance_very_bad"

    cal = 2.0 * metrics["brier"] + 5.0 * metrics["ece"]
    bal = (3.0 * metrics["trim_att_num_smd_max"]
         + 1.0 * metrics["trim_att_num_smd_mean"]
         + 1.0 * metrics["trim_att_cat_smd_p90"]
         + 2.0 * metrics["trim_att_cat_smd_max"])
    stab = 1500.0 / (metrics["trim_att_ess_control"] + 1e-6)
    trim_pen = 2.0 * metrics["trim_drop_rate"]
    return True, float(cal + bal + stab + trim_pen), "ok"

